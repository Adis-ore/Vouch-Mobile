{
  "expo": {
    "name": "Vouch",
    "slug": "vouch",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "vouch",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0A0F1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.vouch.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0F1E"
      },
      "package": "app.vouch.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        { "photosPermission": "Allow Vouch to access your photos for check-in proof." }
      ],
      "expo-web-browser"
    ]
  }
}
